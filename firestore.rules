rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['config', 'filaments', 'products', 'printers', 'sales'])
                   && request.resource.data.filaments is list
                   && request.resource.data.filaments.size() <= 500
                   && request.resource.data.products is list
                   && request.resource.data.products.size() <= 500
                   && request.resource.data.printers is list
                   && request.resource.data.printers.size() <= 100
                   && request.resource.data.sales is list
                   && request.resource.data.sales.size() <= 5000;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
